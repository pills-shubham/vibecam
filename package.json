{
  "name": "vibecam",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Self-hosted WebRTC screen-sharing collaboration platform (mesh, 2-10 peers)",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm run dev --workspace @vibecam/server",
    "dev:client": "npm run dev --workspace @vibecam/client",
    "dev:https": "concurrently -n server,client -c blue,magenta \"npm:dev:server\" \"npm run dev:https --workspace @vibecam/client\"",
    "build": "npm run build --workspace @vibecam/server && npm run build --workspace @vibecam/client",
    "start": "npm run start --workspace @vibecam/server",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc -b --pretty",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "playwright": "^1.61.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
