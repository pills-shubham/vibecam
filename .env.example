# ---- Server ----
PORT=3000
NODE_ENV=development

# ---- CORS / client ----
CLIENT_URL=http://localhost:5173
SOCKET_CORS_ORIGIN=http://localhost:5173

# ---- WebRTC / ICE ----
# Comma-separated list of STUN urls. No TURN required for LAN / most home networks.
STUN_URL=stun:stun.l.google.com:19302

# ---- Peer lifecycle (milliseconds) ----
HEARTBEAT_INTERVAL=30000
PEER_TIMEOUT=60000

# ---- Room limits ----
MAX_ROOM_SIZE=10

# ---- Debug / logging ----
ENABLE_DEBUG=true
LOG_LEVEL=info
